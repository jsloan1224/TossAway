@page "/"
@using GridLab.Services
@inject SheetState Sheet

<PageTitle>SheetState Smoke Test</PageTitle>

<h2>SheetState — initial recalc</h2>
<ul>
@foreach (var row in Sheet.Rows)
{
    var cell = Sheet.Cells[row.RowKey];
    <li>@row.RowKey: @(cell.Error is not null ? $"ERROR: {cell.Error}" : cell.Value?.ToString())</li>
}
</ul>
