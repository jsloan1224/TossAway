@page "/"
@rendermode InteractiveServer
@using GridLab.Services
@using GridLab.Components.Grid
@inject SheetState Sheet

<PageTitle>GridLab</PageTitle>

<div class="sheet-container">
    <SheetGrid Sheet="Sheet"
               SelectedRowKey="_selectedRowKey"
               OnSelectRow="@(key => _selectedRowKey = key)" />
</div>

@code {
    private string? _selectedRowKey;
}
